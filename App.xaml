<Application x:Class="Diploma.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Diploma"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="LoginWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light" 
                                           PrimaryColor="Teal" 
                                           SecondaryColor="Amber" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

            <SolidColorBrush x:Key="AppShellBrush" Color="#F5F2EC"/>
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFDF8"/>
            <SolidColorBrush x:Key="AppMutedSurfaceBrush" Color="#F8FAFC"/>
            <SolidColorBrush x:Key="AppSoftAccentBrush" Color="#E6F2EF"/>
            <SolidColorBrush x:Key="AppPrimaryBrush" Color="#0F766E"/>
            <SolidColorBrush x:Key="AppPrimaryDarkBrush" Color="#174A41"/>
            <SolidColorBrush x:Key="AppTextBrush" Color="#1F2933"/>
            <SolidColorBrush x:Key="AppMutedTextBrush" Color="#667085"/>
            <SolidColorBrush x:Key="AppBorderBrush" Color="#D0D5DD"/>
            <SolidColorBrush x:Key="AppWarmBorderBrush" Color="#E4DED2"/>
            <SolidColorBrush x:Key="AppErrorBrush" Color="#B42318"/>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="44"/>
                <Setter Property="Padding" Value="16,0"/>
                <Setter Property="Background" Value="{StaticResource AppPrimaryBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <Style x:Key="DarkButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                <Setter Property="Background" Value="{StaticResource AppPrimaryDarkBrush}"/>
            </Style>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="42"/>
                <Setter Property="Padding" Value="14,0"/>
                <Setter Property="Background" Value="{StaticResource AppSoftAccentBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource AppPrimaryDarkBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <Style x:Key="OutlineButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="42"/>
                <Setter Property="Padding" Value="14,0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
                <Setter Property="Height" Value="44"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <Style x:Key="ModernPasswordBoxStyle" TargetType="PasswordBox">
                <Setter Property="Height" Value="44"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,0,0,7"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
