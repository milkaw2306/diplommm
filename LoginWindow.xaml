<Window x:Class="Diploma.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Diploma.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Photo Drive - Вход"
        Height="560" Width="860"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Grid Background="{StaticResource AppShellBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*"/>
            <ColumnDefinition Width="0.95*"/>
        </Grid.ColumnDefinitions>

        <Grid Margin="34">
            <Border Background="{StaticResource AppPrimaryDarkBrush}" CornerRadius="10">
                <Grid Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="46" Height="46" Background="#1F8F84" CornerRadius="8">
                            <materialDesign:PackIcon Kind="ImageMultiple"
                                                     Width="25"
                                                     Height="25"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Photo Drive"
                                   Margin="14,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock Text="Ваши фотопапки, теги и доступы в одном месте"
                                   FontSize="34"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   TextWrapping="Wrap"
                                   LineHeight="42"/>
                        <TextBlock Text="Аккуратная галерея с быстрым поиском по названиям и тегам."
                                   Margin="0,18,0,0"
                                   FontSize="15"
                                   Foreground="#D1E7E3"
                                   TextWrapping="Wrap"
                                   LineHeight="23"/>
                    </StackPanel>

                    <UniformGrid Grid.Row="2" Columns="3" Margin="0,24,0,0">
                        <Border Height="88" Margin="0,0,8,0" Background="#26FFFFFF" CornerRadius="8"/>
                        <Border Height="116" Margin="4,0,4,0" Background="#40FFFFFF" CornerRadius="8"/>
                        <Border Height="96" Margin="8,0,0,0" Background="#1FFFFFFF" CornerRadius="8"/>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="1"
                Margin="0,34,34,34"
                Padding="34"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppWarmBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Вход"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AppTextBrush}"/>
                <TextBlock Text="Введите данные аккаунта, чтобы открыть фотодиск."
                           Margin="0,8,0,26"
                           Foreground="{StaticResource AppMutedTextBrush}"
                           TextWrapping="Wrap"/>

                <TextBlock Text="Имя пользователя" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBoxStyle}"
                         materialDesign:HintAssist.Hint="username"/>

                <TextBlock Text="Пароль" Style="{StaticResource FieldLabelStyle}" Margin="0,16,0,7"/>
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource ModernPasswordBoxStyle}"/>

                <Border Margin="0,16,0,0"
                        Padding="12"
                        Background="#FEF3F2"
                        CornerRadius="8"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource AppErrorBrush}"
                               TextWrapping="Wrap"/>
                </Border>

                <Button Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,20,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Login" Width="20" Height="20" Margin="0,0,8,0"/>
                        <TextBlock Text="Войти"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding GoToRegisterCommand}"
                        Style="{StaticResource OutlineButtonStyle}"
                        Margin="0,12,0,0">
                    <TextBlock Text="Создать аккаунт"/>
                </Button>

                <TextBlock HorizontalAlignment="Center" Margin="0,18,0,0">
                    <Hyperlink Command="{Binding ForgotPasswordCommand}">
                        Забыли пароль?
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
