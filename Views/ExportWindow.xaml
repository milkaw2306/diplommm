<Window x:Class="Diploma.Views.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:Diploma.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Экспорт фотографий"
        Height="430" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <!-- Убираем создание DataContext здесь, он будет установлен в коде -->

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Background="{StaticResource AppShellBrush}">
        <Border Margin="26"
                Padding="28"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppWarmBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="50" Height="50" Background="{StaticResource AppSoftAccentBrush}" CornerRadius="8">
                        <materialDesign:PackIcon Kind="DownloadBox"
                                                 Width="28"
                                                 Height="28"
                                                 Foreground="{StaticResource AppPrimaryDarkBrush}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Экспорт фотографий"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AppTextBrush}"/>
                        <TextBlock Text="Выберите папку, куда сохранить выгрузку."
                                   Foreground="{StaticResource AppMutedTextBrush}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,26,0,0">
                    <TextBlock Text="Папка для экспорта" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Text="{Binding ExportPath, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 IsReadOnly="True"
                                 materialDesign:HintAssist.Hint="Папка не выбрана"/>

                        <Button Grid.Column="2"
                                Command="{Binding BrowseFolderCommand}"
                                Style="{StaticResource SecondaryButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FolderSearch" Width="20" Height="20" Margin="0,0,8,0"/>
                                <TextBlock Text="Обзор"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- Информация о экспорте -->
                <Border Grid.Row="2"
                        Margin="0,22,0,0"
                        Padding="16"
                        Background="{StaticResource AppMutedSurfaceBrush}"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="{Binding ExportInfo}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AppTextBrush}"/>
                        <TextBlock Text="Файлы будут сохранены в отдельную папку с датой экспорта."
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource AppMutedTextBrush}"
                                   TextWrapping="Wrap"/>

                        <!-- Прогресс бар -->
                        <ProgressBar Value="{Binding ExportProgress}"
                                     Maximum="100"
                                     Visibility="{Binding IsExporting, Converter={StaticResource BoolToVisibilityConverter}}"
                                     Height="8"
                                     Margin="0,14,0,0"
                                     Foreground="{StaticResource AppPrimaryBrush}"/>

                        <TextBlock Text="{Binding StatusText}"
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource AppMutedTextBrush}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                    <Button Content="Отмена"
                            Style="{StaticResource OutlineButtonStyle}"
                            Width="110"
                            Margin="0,0,10,0"
                            Click="CancelButton_Click"/>

                    <Button Command="{Binding ExportCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="120">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Download" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Экспорт"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>