<Window x:Class="Diploma.Views.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:Diploma.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Photo Drive - Восстановление пароля"
        Height="560" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.DataContext>
        <viewModels:ForgotPasswordViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Background="{StaticResource AppShellBrush}">
        <Border Margin="28"
                Padding="32"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppWarmBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel>
                <Border Width="54"
                        Height="54"
                        Background="{StaticResource AppSoftAccentBrush}"
                        CornerRadius="8"
                        HorizontalAlignment="Left">
                    <materialDesign:PackIcon Kind="LockReset"
                                             Width="30"
                                             Height="30"
                                             Foreground="{StaticResource AppPrimaryDarkBrush}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Восстановление пароля"
                           Margin="0,20,0,0"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AppTextBrush}"/>
                <TextBlock Text="Сначала отправим код на почту, затем вы зададите новый пароль."
                           Margin="0,8,0,24"
                           Foreground="{StaticResource AppMutedTextBrush}"
                           TextWrapping="Wrap"
                           LineHeight="22"/>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCodeSent}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="Email" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBoxStyle}"
                             materialDesign:HintAssist.Hint="name@example.com"/>

                    <Button Command="{Binding SendCodeCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,18,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="EmailFast" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Отправить код"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCodeSent}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border Padding="12"
                            Background="#ECFDF3"
                            CornerRadius="8"
                            Margin="0,0,0,16">
                        <TextBlock Text="Код отправлен. Проверьте почту и введите шесть цифр."
                                   Foreground="#027A48"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="6-значный код" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding ResetCode, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBoxStyle}"
                             MaxLength="6"
                             materialDesign:HintAssist.Hint="000000"/>

                    <TextBlock Text="Новый пароль" Style="{StaticResource FieldLabelStyle}" Margin="0,14,0,7"/>
                    <PasswordBox x:Name="NewPasswordBox"
                                 Style="{StaticResource ModernPasswordBoxStyle}"/>

                    <Button Command="{Binding ResetPasswordCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,18,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ShieldCheck" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Сменить пароль"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Margin="0,16,0,0"
                        Padding="12"
                        Background="#FEF3F2"
                        CornerRadius="8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource AppErrorBrush}"
                               TextWrapping="Wrap"/>
                </Border>

                <Button Command="{Binding GoToLoginCommand}"
                        Style="{StaticResource OutlineButtonStyle}"
                        Margin="0,18,0,0">
                    <TextBlock Text="Вернуться ко входу"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
