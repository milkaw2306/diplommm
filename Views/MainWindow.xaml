<Window x:Class="Diploma.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:Diploma.ViewModels"
        xmlns:converters="clr-namespace:Diploma.Converters"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Photo Drive"
        Height="820" Width="1240"
        MinHeight="720" MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.DataContext>
        <viewModels:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:CollageTileSizeConverter x:Key="CollageTileSizeConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Background="#F5F2EC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0"
                Padding="24,18"
                Background="#FFFDF8"
                BorderBrush="#E4DED2"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="42" Height="42" Background="#174A41" CornerRadius="8">
                        <materialDesign:PackIcon Kind="ImageMultiple"
                                                 Width="24"
                                                 Height="24"
                                                 Foreground="White"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Photo Drive"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2933"/>
                        <TextBlock Text="{Binding BreadcrumbPath}"
                                   Foreground="#667085"
                                   FontSize="13"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        Height="44"
                        MaxWidth="440"
                        Margin="32,0"
                        HorizontalAlignment="Left"
                        Background="#F8FAFC"
                        BorderBrush="#D0D5DD"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Magnify"
                                                 Width="20"
                                                 Height="20"
                                                 Margin="13,0,8,0"
                                                 Foreground="#667085"
                                                 VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 materialDesign:HintAssist.Hint="Поиск по имени или тегам"/>
                        <Button Grid.Column="2"
                                Command="{Binding SearchPhotosCommand}"
                                Width="44"
                                Height="42"
                                Background="Transparent"
                                BorderThickness="0"
                                ToolTip="Найти">
                            <materialDesign:PackIcon Kind="ArrowRight" Width="20" Height="20" Foreground="#174A41"/>
                        </Button>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding CreateFolderCommand}" Height="42" Padding="12,0" Margin="0,0,8,0"
                            Background="#E6F2EF" Foreground="#174A41" BorderThickness="0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FolderPlus" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Папка"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding OpenImportWindowCommand}" Height="42" Padding="12,0" Margin="0,0,8,0"
                            Background="#0F766E" Foreground="White" BorderThickness="0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Upload" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Импорт"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding OpenExportWindowCommand}" Height="42" Padding="12,0" Margin="0,0,8,0"
                            Background="#174A41" Foreground="White" BorderThickness="0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Download" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Экспорт"/>
                        </StackPanel>
                    </Button>
                    <Button Click="Exit_Click" Width="42" Height="42" Background="Transparent" BorderBrush="#D0D5DD" ToolTip="Выход">
                        <materialDesign:PackIcon Kind="Logout" Width="20" Height="20" Foreground="#344054"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель -->
            <Border Grid.Column="0"
                    Margin="24"
                    Padding="18"
                    Background="#FFFDF8"
                    BorderBrush="#E4DED2"
                    BorderThickness="1"
                    CornerRadius="8">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Папки"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2933"/>
                        <TextBlock Text="{Binding TotalFolders, StringFormat={}{0} в этом разделе}"
                                   Margin="0,4,0,14"
                                   Foreground="#667085"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Folders}"
                             SelectedItem="{Binding SelectedFolder}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Command="{Binding DataContext.NavigateToFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            HorizontalContentAlignment="Stretch"
                                            Background="#F8FAFC"
                                            BorderBrush="#E4E7EC"
                                            BorderThickness="1"
                                            Padding="12"
                                            MinHeight="48">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Folder" Width="21" Height="21" Foreground="#0F766E" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding FolderName}"
                                                       Foreground="#344054"
                                                       FontWeight="Medium"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Click="FolderContextMenu_Click"
                                            Width="38"
                                            Height="48"
                                            Margin="6,0,0,0"
                                            Background="Transparent"
                                            BorderThickness="0">
                                        <materialDesign:PackIcon Kind="DotsVertical" Width="20" Height="20" Foreground="#667085"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Правая область -->
            <Grid Grid.Column="1" Margin="0,24,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="18"
                        Background="#FFFDF8"
                        BorderBrush="#E4DED2"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentPath}"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#1F2933"/>
                            <TextBlock Text="{Binding TotalPhotos, StringFormat={}{0} фото в подборке}"
                                       Margin="0,4,0,0"
                                       Foreground="#667085"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Command="{Binding RefreshCommand}" Width="42" Height="42" Margin="0,0,8,0"
                                    Background="#F8FAFC" BorderBrush="#D0D5DD" ToolTip="Обновить">
                                <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" Foreground="#344054"/>
                            </Button>
                            <Button Command="{Binding SelectAllPhotosCommand}" Height="42" Padding="12,0"
                                    Background="#E6F2EF" Foreground="#174A41" BorderThickness="0">
                                <TextBlock Text="Выбрать все"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ListBox Grid.Row="1" 
         Margin="0,18,0,0"
         ItemsSource="{Binding Photos}"
         Background="Transparent"
         BorderThickness="0"
         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
         ScrollViewer.VerticalScrollBarVisibility="Auto">

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="240"
                    Height="280"
                    Background="White"
                    CornerRadius="10"
                    BorderBrush="#E4E7EC"
                    BorderThickness="1"
                    Margin="8">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="190"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Фото -->
                                    <Border Grid.Row="0" 
                            Background="#F8FAFC"
                            CornerRadius="10,10,0,0">
                                        <Image Source="{Binding Thumbnail}"
                               Stretch="Uniform"
                               StretchDirection="DownOnly"/>
                                    </Border>

                                    <!-- Информация -->
                                    <StackPanel Grid.Row="1" 
                                Margin="10,8,10,10">
                                        <TextBlock Text="{Binding OriginalName}"
                                   Foreground="#1F2933"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Text="{Binding Dimensions}"
                                   Foreground="#667085"
                                   FontSize="10"
                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- Кнопка меню -->
                                    <Button Click="PhotoContextMenu_Click"
                            Width="26"
                            Height="26"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="6"
                            Background="#E6F2EF"
                            BorderThickness="0">
                                        <materialDesign:PackIcon Kind="DotsVertical" 
                                                 Width="12" 
                                                 Height="12" 
                                                 Foreground="#174A41"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <!-- Нижняя панель -->
        <StatusBar Grid.Row="2" Background="#FFFDF8" BorderBrush="#E4DED2" BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding UserName, StringFormat=Пользователь: {0}}" Foreground="#344054"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Foreground="#667085"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding StorageDisplay}" Margin="0,0,10,0" Foreground="#344054"/>
                    <ProgressBar Value="{Binding StoragePercent}" Width="160" Height="8" Foreground="#0F766E"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>