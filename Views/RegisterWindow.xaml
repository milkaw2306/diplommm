<Window x:Class="Diploma.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:Diploma.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Photo Drive - Регистрация"
        Height="720" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.DataContext>
        <viewModels:RegisterViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Background="{StaticResource AppShellBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Margin="28,28,0,28"
                Padding="28"
                Background="{StaticResource AppPrimaryDarkBrush}"
                CornerRadius="10">
            <StackPanel>
                <Border Width="52" Height="52" Background="#1F8F84" CornerRadius="8" HorizontalAlignment="Left">
                    <materialDesign:PackIcon Kind="AccountPlus"
                                             Width="28"
                                             Height="28"
                                             Foreground="White"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Новый аккаунт"
                           Margin="0,24,0,0"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="White"
                           TextWrapping="Wrap"/>
                <TextBlock Text="Создайте профиль, чтобы хранить фотографии по папкам, тегировать загрузки и делиться доступом."
                           Margin="0,14,0,0"
                           Foreground="#D1E7E3"
                           TextWrapping="Wrap"
                           LineHeight="23"/>

                <StackPanel Margin="0,34,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <materialDesign:PackIcon Kind="TagMultiple" Width="20" Height="20" Foreground="#A7F3D0" Margin="0,0,10,0"/>
                        <TextBlock Text="Теги для будущего AI-поиска" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <materialDesign:PackIcon Kind="ShareVariant" Width="20" Height="20" Foreground="#A7F3D0" Margin="0,0,10,0"/>
                        <TextBlock Text="Коды доступа и отправка email" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ImageMultiple" Width="20" Height="20" Foreground="#A7F3D0" Margin="0,0,10,0"/>
                        <TextBlock Text="Красивая фотоплитка" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Margin="24,28,28,28"
                Padding="34"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppWarmBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Регистрация"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppTextBrush}"/>
                    <TextBlock Text="Заполните данные. Обязательные поля отмечены звездочкой."
                               Margin="0,8,0,24"
                               Foreground="{StaticResource AppMutedTextBrush}"/>

                    <TextBlock Text="Имя пользователя *" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBoxStyle}"
                             materialDesign:HintAssist.Hint="username"/>

                    <TextBlock Text="Полное имя" Style="{StaticResource FieldLabelStyle}" Margin="0,14,0,7"/>
                    <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBoxStyle}"
                             materialDesign:HintAssist.Hint="Иван Иванов"/>

                    <TextBlock Text="Email *" Style="{StaticResource FieldLabelStyle}" Margin="0,14,0,7"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBoxStyle}"
                             materialDesign:HintAssist.Hint="name@example.com"/>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Пароль *" Style="{StaticResource FieldLabelStyle}"/>
                            <PasswordBox x:Name="PasswordBox"
                                         Style="{StaticResource ModernPasswordBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Повтор пароля *" Style="{StaticResource FieldLabelStyle}"/>
                            <PasswordBox x:Name="ConfirmPasswordBox"
                                         Style="{StaticResource ModernPasswordBoxStyle}"/>
                        </StackPanel>
                    </Grid>

                    <Border Margin="0,16,0,0"
                            Padding="12"
                            Background="#FEF3F2"
                            CornerRadius="8"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource AppErrorBrush}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Button Command="{Binding RegisterCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,22,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountCheck" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Зарегистрироваться"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding GoToLoginCommand}"
                            Style="{StaticResource OutlineButtonStyle}"
                            Margin="0,12,0,0">
                        <TextBlock Text="Уже есть аккаунт? Войти"/>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
